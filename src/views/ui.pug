			flex-direction: row;
			flex-wrap: wrap;
			align-items: flex-end;
			column-gap: 16px;
		}

		.pv-block__items--align-start {
			align-items: flex-start;
		}

		.skeleton-preview-card {
			display: flex;
			flex-direction: column;
			gap: 12px;
			width: 280px;
		}

		.skeleton-preview-card__image {
			width: 100%;
			height: 148px;
			border-radius: 8px;
			background-color: var(--color-neutral-200);
		}

		.skeleton-preview-card__title {
			margin: 0;
