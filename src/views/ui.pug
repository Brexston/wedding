								button.tab.tab--default(v-initial-scroll=tab === 'All' :class=`getActiveClass('${tab}')` v-on=`tabEvents('${tab}')`)=tab

						.tab-content
							br
							template(v-if="['All', 'Breadcrumbs'].includes(activeTab)")
