block head
	style.
		.project-view {
			--view-bg: var(--body-bg);
			--view-color: var(--body-color);
			--view-block-bg: var(--color-neutral-100);
			--view-border: var(--default-border);
			--view-link: var(--body-color);
			--view-link-hover: var(--color-primary-500);
			--view-title-color: var(--body-color);
			--view-check: var(--color-primary-300);
			position: relative;
			z-index: 0;
			display: flex;
			flex-direction: column;
			width: 100%;
			min-height: 100vh;
			padding: fluid(60, 40) 0;
			background-color: var(--view-bg);
			color: var(--view-color);
		}

		.project-view .default-input__input {
			min-width: 250px;
		}

		.wrapper {
			display: flex;
			flex: 1 1 100%;
			flex-direction: column;
		}

		.pv-title {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 20px;
			margin-bottom: fluid(60, 24);
		}

		.pv-title__text {
			margin: 0;
			color: var(--view-color);
			font-size: fluid(32, 18);
			font-weight: 600;
		}

		.pv-logo {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.pv-logo__image.img {
			--width: fluid(270, 180);
			--aspect-ratio: 270/70;
			--object-fit: contain;
		}

		.pv-blocks {
			width: 100%;
		}

		.pv-blocks--columns {
			column-count: auto;
			column-width: clamp(16rem, 45vw, 32rem);
