extends /base/_head

block vars
	- let title = 'UI Kit'
	- let layoutClass = null
	- let bodyClass = null

block content
	main.page__main
		+page-header({title: 'UI Kit',})
			+slot('actions')
				a.link.link--color-primary(href=`${BASE_URL}`) Назад
