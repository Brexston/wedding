		.pv-blocks--list {
			display: grid;
			grid-template-columns: minmax(0, 1fr);
			gap: 16px;
		}

		.pv-block {
			display: flex;
			flex-direction: column;
			width: 100%;
			padding: fluid(24, 20);
			background-color: var(--view-block-bg);
		}

		.pv-block__video {
			width: 500px;
			height: 333px;
		}

		.pv-block--dark {
