			--di-bg-focus: var(--color-neutral-900);
			--di-border-color: var(--color-primary-400);
			--di-border-color-hover: var(--color-primary-300);
			--di-border-color-focus: var(--color-primary-300);
			--di-label-color: var(--color-neutral-200);
