												template(#content)
													p positioning-disabled: отключение динамического позиционирования всплывающего меню (включено).

											x-dropdown(:triggers=['hover', 'click'] :distance="10")
												button.btn Hover

												template(#content)
													p triggers: события для открытия всплывающего меню (hover и click).

											x-dropdown(:triggers=['hover', 'click'] :popper-triggers=['hover'] :distance="10")
												button.btn Hover (popper triggers)

												template(#content)
													p triggers: события для открытия всплывающего меню (hover и click).
													p popper-triggers: альтернативные события для управления popper отдельно от триггера (hover).

											x-dropdown(placement="top-start" :distance="10")
												button.btn Placement Top-Start

												template(#content)
													p placement: начальная позиция всплывающего меню относительно триггера (top-start).

