												template(#trigger="{hasOverflow, isActive, toggleActive}")
													button.link.link--color-primary(v-if="hasOverflow" @click="toggleActive") Показать еще

										.toggle-text
											x-show-more().toggle-text__content
												p Тут будет не только кнопка <span style="color: #336699">'Показать еще'</span>, но и кнопка <span style="color: #336699">'Скрыть'</span>. пам-пам.  пам-пам. пам-пам. пам-пам. пам-пам. пам-пам. пам-пам. пам-пам. пам-пам. пам-пам.
