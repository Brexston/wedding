													button.link.link--color-primary(v-else-if="isActive" @click="toggleActive") Скрыть

							template(v-if="['All', 'Icons'].includes(activeTab)")
								.pv-block
									h3.pv-block__title Icon
									.pv-block__preview

										p Просто иконки (например лайки, просмотры, дата у новости и т.д)
										.pv-block__items.pv-block__items--row
											.pv-block__item
												+icon('arrow-right').icon
											.pv-block__item
												+icon('calendar').icon
											.pv-block__item
												+icon('clip').icon

							template(v-if="['All', 'Dropdowns'].includes(activeTab)")
								.pv-block
									h3.pv-block__title Dropdown
									.pv-block__preview
										.pv-block__items.pv-block__items--row
											x-dropdown(aria-id="dropdown-1" :distance="10")
												button.btn AriaId

												template(#content)
													p aria-id: идентификатор для привязки aria-describedby и контейнера.
													p distance: расстояние между триггером и всплывающим меню (10px).

											x-dropdown(:delay="2000" placement="top" :distance="10")
												button.btn Delay 2s

												template(#content)
													p delay: задержка открытия/закрытия (2000мс).
													p placement: начальная позиция всплывающего меню относительно триггера (top).

											x-dropdown(:delay="{ show: 0, hide: 1000 }" placement="top" :distance="10")
												button.btn Show 0s, Hide 1s

												template(#content)
													p delay: объект с задержками для show (0мс) и hide (1000мс).
													p placement: начальная позиция всплывающего меню относительно триггера (top).

											x-dropdown(shift shift-cross-axis :distance="10")
												button.btn Strategy fixed + shift axis

												template(#content)
													p shift: смещение dropdown при нехватке места (включено).
													p shift-cross-axis: смещение вдоль перпендикулярной оси (включено).
													p strategy: стратегия позиционирования popper (fixed, по умолчанию).

											x-dropdown(shift shift-cross-axis strategy='absolute' :distance="10")
												button.btn Strategy absolute + shift axis

												template(#content)
													p shift: смещение dropdown при нехватке места (включено).
													p shift-cross-axis: смещение вдоль перпендикулярной оси (включено).
													p strategy: стратегия позиционирования popper (absolute).

											x-dropdown(theme='null' placement="bottom" :distance="10")
												button.btn Theme: null

												template(#content)
													p(style="padding: 10px; background-color: #cccccc; border-radius: 10px") Прозрачная тема без стрелок и фона, чтобы отображать только проброшенный контент (например, этот абзац с черным текстом на сером фоне со скругленными углами)

											x-dropdown(theme='without-arrow' :distance="10")
												button.btn Theme: without-arrow

												template(#content)
													p theme: тема оформления всплывающего меню (without-arrow - без стрелки).

											x-dropdown(:distance="10")
												button.btn With Hide btn

												template( #content={ hide } )
													p В слоте content доступна функция hide для программного закрытия dropdown.
													button.btn(@click="hide").btn.btn--color-secondary Закрыть

											x-dropdown(positioning-disabled :distance="10")
